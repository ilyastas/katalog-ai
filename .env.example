# Environment-specific configuration
ENVIRONMENT=development

# FastAPI
DEBUG=true
LOG_LEVEL=INFO

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# PostgreSQL Configuration
DATABASE_URL=postgresql://alie_user:postgres123@localhost:5432/alie_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=0

# Redis Configuration  
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_CACHE_TTL=3600

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# API Keys (Get from GitHub Secrets or .env.local)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_ASSISTANT_ID=asst_your-assistant-id-here
TWOGIS_API_KEY=your-2gis-api-key
APIFY_TOKEN=your-apify-token
GOOGLE_PLACES_KEY=your-google-api-key

# CORS Settings
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Application Settings
APP_NAME=ALIE - AI Lead Intelligence Engine
APP_VERSION=1.0.0
API_V1_STR=/api/v1

# Data URLs
CATALOG_BASE_URL=https://ilyastas.github.io/katalog-ai
DATA_INDEX_URL=https://ilyastas.github.io/katalog-ai/data/index.json

# Verification Settings
VERIFICATION_TIMEOUT=30
MAX_RETRIES=3

# Analytics
TRACK_EVENTS=true
ANALYTICS_DB=alie_db
ANALYTICS_TABLE=lead_events

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
