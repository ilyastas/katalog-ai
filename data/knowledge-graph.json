  "scoring_rules": {
    "semantic_similarity": {
      "description": "Cosine similarity between query embedding and company embedding",
      "weight": 0.50,
      "range": [0, 1]
    },
    "trust_score": {
      "description": "Verification and review-based trust metric",
      "weight": 0.20,
      "range": [0, 1],
      "sources": ["Google Places", "2GIS", "OLX"]
    },
    "update_freshness": {
      "description": "How recently the company profile was updated",
      "weight": 0.20,
      "range": [0, 1],
      "formula": "1 / (1 + days_since_update)"
    },
    "popularity": {
      "description": "Query frequency and click-through rate",
      "weight": 0.10,
      "range": [0, 1],
      "sources": ["usage_telemetry"]
    }
  },
  "reasoning_patterns": {
    "direct_service_match": {
      "pattern": "query → service_node → company_node",
      "example": "user asks for 'immigration lawyer' → finds immigration_lawyer service node → retrieves Astana Legal Group company",
      "confidence": 0.95
    },
    "category_expansion": {
      "pattern": "query → category → all_services → companies",
      "example": "user asks for 'legal help' → finds legal_services category → returns all legal service providers",
      "confidence": 0.85
    },
    "location_proximity": {
      "pattern": "location_query + service → location_node → companies_in_location",
      "example": "user asks for 'salon in Almaty' → finds Almaty location → filters for beauty services → returns Beauty Premium Almaty",
      "confidence": 0.90
    },
    "semantic_similarity_ranking": {
      "pattern": "query_embedding → similarity_search → ranked_results",
      "example": "user asks for 'startup support' → semantic search finds Tech Startup Hub despite different keywords",
      "confidence": 0.88
    },
    "multi_hop_reasoning": {
      "pattern": "start_node → intermediate_node → target_node",
      "example": "user asks for 'cultural activities near restaurants in Almaty' → location:almaty → category:culture → similar to category:food → returns nearby options",
      "confidence": 0.80
    }
  },
  "retrieval_algorithm": {
    "name": "Hybrid Semantic + Graph Traversal",
    "steps": [
      "1. Embed user query using OpenAI embeddings API",
      "2. Perform vector similarity search on company embeddings",
      "3. Apply graph filters (category, location, service type)",
      "4. Calculate final_score = 0.5*semantic_similarity + 0.2*trust_score + 0.2*update_freshness + 0.1*popularity",
      "5. Rank results by final_score (descending)",
      "6. Return top-k with explanation of why each match was selected"
    ]
  },
