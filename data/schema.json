{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilyastas.github.io/katalog-ai/data/schema.json",
  "title": "KATALOG-AI Company Schema",
  "description": "Strict schema definition for validating company objects in the catalog",
  "version": "1.0.0",
  
  "definitions": {
    "Company": {
      "type": "object",
      "required": ["id", "name", "slug", "category", "country", "city", "url", "description", "verification"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Unique company identifier (lowercase, hyphens only)"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200,
          "description": "Official company name"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "URL-friendly company identifier"
        },
        "country": {
          "type": "string",
          "enum": ["Kazakhstan", "Russia", "Kyrgyzstan", "Tajikistan", "Uzbekistan", "Turkmenistan", "Online", "CIS"],
          "description": "Company country of operation"
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "City of operation (or 'Online' for e-commerce)"
        },
        "geo": {
          "type": "string",
          "description": "Geographical region description"
        },
        "category": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "Primary business category"
        },
        "industry": {
          "type": "string",
          "minLength": 2,
          "maxLength": 100,
          "description": "Industry classification"
        },
        "service": {
          "type": "string",
          "description": "Primary service or product type"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000,
          "description": "Detailed description of the company (required for RAG)"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Primary website or social media URL"
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "Official website URL"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50
          },
          "minItems": 1,
          "description": "SEO and semantic search keywords (required for RAG semantic matching)"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "description": "Categorical tags for filtering"
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of services or products offered"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["Russian", "Kazakh", "English", "Kyrgyz", "Tajik", "Uzbek", "Turkmen"]
          },
          "description": "Languages supported by the company"
        },
        "social": {
          "type": "object",
          "description": "Social media presence",
          "properties": {
            "instagram": {
              "type": "string",
              "format": "uri"
            },
            "telegram": {
              "type": "string",
              "format": "uri"
            },
            "whatsapp": {
              "type": "string"
            },
            "facebook": {
              "type": "string",
              "format": "uri"
            },
            "linkedin": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "contact": {
          "type": "object",
          "description": "Contact information",
          "properties": {
            "email": {
              "type": "string",
              "format": "email"
            },
            "phone": {
              "type": "string",
              "pattern": "^\\+?[0-9\\s\\-()]{10,}$"
            }
          }
        },
        "metrics": {
          "type": "object",
          "description": "Performance metrics",
          "properties": {
            "followers": {
              "type": "integer",
              "minimum": 0
            },
            "rating": {
              "type": "number",
              "minimum": 0,
              "maximum": 5
            },
            "sales": {
              "type": "integer",
              "minimum": 0
            },
            "years_on_market": {
              "type": "integer",
              "minimum": 0
            },
            "location": {
              "type": "string"
            }
          }
        },
        "verification": {
          "type": "object",
          "required": ["status"],
          "description": "Verification information (mandatory)",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["verified", "pending", "unverified"],
              "description": "Verification status"
            },
            "sources": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["instagram", "telegram", "email", "phone", "website", "marketplace", "government"]
              },
              "description": "Verification sources"
            },
            "verified_at": {
              "type": "string",
              "format": "date-time",
              "description": "ISO-8601 timestamp of verification"
            }
          }
        },
        "semantic_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Internal semantic keyword field (for backwards compatibility)"
        },
        "same_as": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "description": "Schema.org same_as references"
        },
        "marketplace": {
          "type": "object",
          "description": "Marketplace presence (for e-commerce vendors)",
          "properties": {
            "platform": {
              "type": "string"
            },
            "brand_url": {
              "type": "string",
              "format": "uri"
            },
            "seller_id": {
              "type": "string"
            }
          }
        }
      },
      "additionalProperties": false
    }
  },

  "type": "object",
  "description": "Root schema for companies.json",
  "required": ["version", "timestamp", "count", "companies"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "authoritative": {
      "type": "boolean"
    },
    "source": {
      "type": "string",
      "format": "uri"
    },
    "companies": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Company"
      }
    }
  }
}
