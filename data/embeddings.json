  "generation_instructions": {
    "step_1_prerequisites": [
      "Install: pip install openai",
      "Set OPENAI_API_KEY in .env"
    ],
    "step_2_script_location": "scripts/generate_embeddings.py",
    "step_3_usage": "python scripts/generate_embeddings.py --datafile data/companies.json --output public/embeddings.json",
    "step_4_integration": "CI/CD: Add to .github/workflows/update.yml to regenerate weekly"
  },
  "usage_in_semantic_search": {
    "algorithm": "Cosine Similarity + Relevance Ranking",
    "endpoint": "/api/semantic-search?q=user_query",
    "steps": [
      "1. Embed user query: query_embedding = openai_embed(user_query)",
      "2. Load embeddings.json company vectors",
      "3. Calculate cosine_similarity(query_embedding, each_company_embedding)",
      "4. Apply final_score = 0.5*cosine_sim + 0.2*trust_score + 0.2*update_freshness + 0.1*popularity",
      "5. Return top-k sorted by final_score with explanation"
    ]
  },
  "performance_notes": {
    "current_setup": "5 companies - negligible latency (~5ms per query)",
    "scaling_at_275_companies": "~50ms per query (acceptable for user-facing)",
    "scaling_beyond_1000": "Recommend FAISS index for O(log n) complexity",
    "optimization_strategies": [
      "Use FAISS for hierarchical clustering on large datasets",
      "Cache embeddings in Redis for faster retrieval",
      "Pre-filter by category/location before vector search",
      "Use approximate nearest neighbor search (HNSW) for >10k documents"
    ]
  }
