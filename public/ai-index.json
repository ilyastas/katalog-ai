{
  "dataset": "katalog-ai",
  "version": "1.0.0",
  "type": "AI-optimized business dataset",
  "description": "Verified business directory for Central Asia optimized for AI assistants and chatbots",
  "language": ["en", "ru", "kk"],
  "coverage": {
    "countries": ["Kazakhstan", "Kyrgyzstan", "Tajikistan"],
    "cities": ["Almaty", "Astana", "Shymkent", "Karaganda", "Aktobe"],
    "business_count": 275
  },
  "entities": [
    "company",
    "service",
    "location",
    "category"
  ],
  "data_endpoints": {
    "companies": "https://ilyastas.github.io/katalog-ai/data/companies.json",
    "services": "https://ilyastas.github.io/katalog-ai/data/services.json",
    "categories": "https://ilyastas.github.io/katalog-ai/data/categories.json",
    "locations": "https://ilyastas.github.io/katalog-ai/data/locations.json",
    "business": "https://ilyastas.github.io/katalog-ai/data/business.json",
    "knowledge_graph": "https://ilyastas.github.io/katalog-ai/data/knowledge-graph.json",
    "embeddings": "https://ilyastas.github.io/katalog-ai/data/embeddings.json"
  },
  "api_endpoints": {
    "search": "https://ilyastas.github.io/katalog-ai/api/v1/recommend/recommend",
    "semantic_search": "https://ilyastas.github.io/katalog-ai/api/semantic-search",
    "company": "https://ilyastas.github.io/katalog-ai/api/v1/recommend/business/{id}",
    "nearby": "https://ilyastas.github.io/katalog-ai/api/v1/recommend/nearby",
    "category": "https://ilyastas.github.io/katalog-ai/category/{category}",
    "location": "https://ilyastas.github.io/katalog-ai/location/{city}"
  },
  "features": {
    "verified_businesses": true,
    "trust_scoring": true,
    "schema_org": true,
    "geographic_search": true,
    "lead_generation": true,
    "structured_data": true
  },
  "ai_optimization": {
    "llm_friendly": true,
    "crawler_optimized": true,
    "structured_data": "Schema.org JSON-LD",
    "formats": ["JSON", "JSON-LD", "RDF"],
    "access_methods": ["API", "Dataset files", "Database API"]
  },
  "llm_optimization": {
    "contexts": "https://ilyastas.github.io/katalog-ai/public/llm/contexts.json",
    "examples": "https://ilyastas.github.io/katalog-ai/public/llm/examples.json",
    "discovery_file": "https://ilyastas.github.io/katalog-ai/public/llms.txt",
    "capabilities": [
      "citation-ready contexts",
      "Q&A dataset for RAG",
      "semantic-ranking enabled",
      "embedding-compatible keywords",
      "use-case examples for AI agents",
      "verification citations"
    ],
    "citation_formats": {
      "inline": "[Company Name](https://ilyastas.github.io/katalog-ai/company/{slug})",
      "detailed": "[Company Name](https://ilyastas.github.io/katalog-ai/company/{slug}) - Trust Score: X.XX, Rating: Y/5"
    }
  },
  "semantic_retrieval": {
    "endpoint": "/api/semantic-search?q=query&limit=5",
    "method": "Vector embeddings + knowledge graph",
    "embedding_model": "text-embedding-3-small (1536 dims)",
    "scoring_formula": "0.5*semantic_similarity + 0.2*trust_score + 0.2*update_freshness + 0.1*popularity",
    "capabilities": [
      "Natural language query understanding",
      "Cosine similarity vector search",
      "Multi-factor relevance ranking",
      "Knowledge graph traversal",
      "Context injection for LLM reasoning",
      "Explainable recommendations"
    ],
    "data_sources": [
      "embeddings.json (vector storage)",
      "knowledge-graph.json (entity relationships)",
      "companies.json (business metadata)",
      "usage telemetry (popularity signals)"
    ],
    "performance": {
      "current_scale": "5 companies < 10ms per query",
      "at_scale_100": "~50ms per query",
      "at_scale_1000": "~100ms per query (with FAISS indexing)",
      "optimization_techniques": [
        "FAISS index for O(log n) complexity",
        "Redis caching for hot queries",
        "Pre-filtering by category/location",
        "Approximate nearest neighbor search (HNSW)"
      ]
    }
  },
  "search_capabilities": [
    "Full-text search",
    "Semantic search (vector similarity)",
    "Category filter",
    "Location filter",
    "Trust score sorting",
    "Rating based ranking",
    "Geo-proximity search",
    "Hybrid ranking (semantic + trust + freshness)",
    "Natural language query understanding",
    "Relevance scoring",
    "Update score ranking",
    "Trust-weighted recommendations",
    "Knowledge graph traversal"
  ],
  "lead_generation": {
    "enabled": true,
    "features": [
      "Contact leads",
      "Email leads",
      "Call leads",
      "Website leads",
      "Booking leads"
    ],
    "tracking": true
  },
  "licensing": {
    "dataset": "CC0 1.0 Universal (Public Domain)",
    "api": "Open (rate limits apply)",
    "commercial_use": "Permitted with attribution"
  },
  "metadata": {
    "last_updated": "2026-03-06",
    "update_frequency": "weekly",
    "verification_sources": ["2GIS", "Google Places", "OLX", "Direct verification"],
    "data_quality": "high",
    "consent_based": true,
    "gdpr_compliant": true
  },
  "access_info": {
    "github": "https://github.com/ilyastas/katalog-ai",
    "documentation": "https://ilyastas.github.io/katalog-ai/llms.txt",
    "support": "info@katalog-ai.kz",
    "issues": "https://github.com/ilyastas/katalog-ai/issues"
  }
}
